{
  "$schema": "https://example.invalid/ai-migration-framework/schemas/migration-config.schema.json",
  "schema_version": "2.0",
  "framework_version": "2.0.0",
  "profiles": {"source": "cpp", "target": "java-25", "pair": "cpp-to-java-25"},
  "output_profile": "service",
  "migration_strategy": "incremental",
  "source_root": "./legacy",
  "target_root": "./app",
  "quality_gates": {
    "required_checks": ["behavioral-contracts", "build", "tests", "architecture", "static-analysis", "dependency-integrity"],
    "coverage": {
      "metric": "changed-code",
      "threshold_percent": 90,
      "rationale": "High-risk concurrency and persistence slices require strong changed-code exercise in addition to differential contracts."
    }
  },
  "project_decisions": {"cutover_mechanism": "route-by-capability"},
  "validation_status": "valid"
}
