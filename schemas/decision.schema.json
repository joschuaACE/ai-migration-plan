{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/decision.schema.json",
  "title": "Migration decision",
  "type": "object",
  "required": ["schema_version", "id", "status", "context", "decision", "consequences", "affected_contracts", "approvals"],
  "properties": {
    "$schema": {"type": "string"}, "schema_version": {"const": "2.0"}, "id": {"type": "string", "pattern": "^DEC-[0-9]{4,}$"}, "status": {"enum": ["proposed", "accepted", "rejected", "superseded"]}, "context": {"type": "string"}, "decision": {"type": "string"}, "consequences": {"type": "array", "items": {"type": "string"}}, "affected_contracts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^BEH-[0-9]{4,}$"}}, "approvals": {"type": "array", "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
