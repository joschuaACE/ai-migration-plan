{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/evidence-v3.schema.json",
  "title": "Reproducible verification evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "phase", "slice_id", "gate", "status", "command", "working_directory", "exit_code", "environment", "artifacts", "contracts", "recorded_at"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "3.0"},
    "id": {"type": "string", "pattern": "^EVID-[0-9]{4,}$"},
    "phase": {"enum": ["characterize", "verify", "cut_over", "decommission"]},
    "slice_id": {"type": ["string", "null"], "pattern": "^SLICE-[0-9]{4,}$"},
    "gate": {"type": "string", "minLength": 1},
    "status": {"enum": ["pass", "fail", "waived"]},
    "command": {"type": "string", "minLength": 1},
    "working_directory": {"$ref": "#/$defs/relativePath"},
    "exit_code": {"type": "integer", "minimum": 0},
    "environment": {"type": "object", "additionalProperties": {"type": "string"}},
    "artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "contracts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^BEH-[0-9]{4,}$"}},
    "recorded_at": {"type": "string", "format": "date-time"},
    "depth_metrics": {
      "description": "Quantitative depth metrics proving the evidence exercises real behavioral substance, not just structural compilation. Required when depth_policy is enforced.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "observations_exercised": {
          "description": "Number of distinct BEH observations individually exercised by this evidence",
          "type": "integer",
          "minimum": 0
        },
        "total_observations": {
          "description": "Total observations declared in the referenced contracts",
          "type": "integer",
          "minimum": 1
        },
        "assertions": {
          "description": "Number of test assertions (assertEquals, assertTrue, etc.) in the test suite run by this evidence",
          "type": "integer",
          "minimum": 0
        },
        "source_lines": {
          "description": "Total non-blank source lines in the legacy files covered by this evidence's contracts",
          "type": "integer",
          "minimum": 0
        },
        "target_lines": {
          "description": "Total non-blank lines in the target production files produced for this evidence's contracts",
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "relativePath": {"type": "string", "pattern": "^(?:\\.|(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+)$"}
  }
}
