{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/target-inventory.schema.json",
  "title": "Target implementation and test inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "migration_id", "units"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "3.0"},
    "migration_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "units": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "kind", "status", "sha256"],
        "properties": {
          "id": {"type": "string", "pattern": "^(?:TGT|TEST)-[0-9]{4,}$"},
          "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
          "kind": {"enum": ["production", "test", "build", "resource", "config", "documentation", "other"]},
          "status": {"enum": ["planned", "present", "removed"]},
          "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
