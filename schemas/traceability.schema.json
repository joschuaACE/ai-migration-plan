{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/traceability.schema.json",
  "title": "End-to-end migration traceability",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "migration_id", "links"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "2.0"},
    "migration_id": {"type": "string"},
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_unit", "behavioral_contracts", "target_units", "tests", "decisions", "evidence", "exceptions", "status"],
        "properties": {
          "source_unit": {"type": "string", "pattern": "^SRC-[0-9]{4,}$"},
          "behavioral_contracts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^BEH-[0-9]{4,}$"}},
          "target_units": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^TGT-[0-9]{4,}$"}},
          "tests": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^TEST-[0-9]{4,}$"}},
          "decisions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^DEC-[0-9]{4,}$"}},
          "evidence": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^EVID-[0-9]{4,}$"}},
          "exceptions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^EXC-[0-9]{4,}$"}},
          "status": {"enum": ["unmapped", "planned", "implemented", "verified", "approved", "excepted"]}
        }
      }
    }
  }
}
