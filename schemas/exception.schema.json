{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/exception.schema.json",
  "title": "Migration policy exception",
  "type": "object",
  "required": ["schema_version", "id", "category", "status", "scope", "rationale", "impact", "mitigation", "approvals", "expires_at"],
  "properties": {
    "$schema": {"type": "string"}, "schema_version": {"const": "2.0"}, "id": {"type": "string", "pattern": "^EXC-[0-9]{4,}$"}, "category": {"enum": ["dead-code", "intentional-change", "unspecified-behavior", "unsupported-dependency", "unsupported-platform", "quality-gate"]}, "status": {"enum": ["proposed", "approved", "rejected", "expired"]}, "scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^(?:SRC|BEH|TGT|TEST|DEC|SLICE|EVID)-[0-9]{4,}$"}}, "rationale": {"type": "string"}, "impact": {"type": "string"}, "mitigation": {"type": "string"}, "approvals": {"type": "array", "items": {"type": "string"}}, "expires_at": {"type": ["string", "null"], "format": "date-time"}
  },
  "additionalProperties": false
}
