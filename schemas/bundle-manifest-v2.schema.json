{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/bundle-manifest-v2.schema.json",
  "title": "Compiled migration bundle manifest (v2 compatibility)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "framework_version", "bundle_format_version", "profiles", "adapter", "adapter_capabilities", "variables", "source_checksums", "generated_files", "bundle_digest"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "2.0"},
    "framework_version": {"type": "string"},
    "bundle_format_version": {"const": "2.0"},
    "profiles": {
      "type": "object",
      "required": ["source", "target", "pair", "output"],
      "properties": {
        "source": {"type": "string"}, "target": {"type": "string"}, "pair": {"type": "string"}, "output": {"type": "string"}
      },
      "additionalProperties": false
    },
    "adapter": {"enum": ["kiro", "claude", "codex", "portable"]},
    "adapter_capabilities": {"type": "object"},
    "variables": {"type": "object", "additionalProperties": {"type": ["string", "number", "boolean"]}},
    "source_checksums": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
    "generated_files": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}},
    "bundle_digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
