{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/behavioral-contract.schema.json",
  "title": "Characterized observable behavior",
  "type": "object",
  "required": ["schema_version", "id", "source_units", "preconditions", "stimulus", "observations", "evidence", "known_gaps"],
  "properties": {
    "$schema": {"type": "string"}, "schema_version": {"enum": ["2.0", "2.1"]}, "id": {"type": "string", "pattern": "^BEH-[0-9]{4,}$"},
    "source_units": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^SRC-[0-9]{4,}$"}}, "preconditions": {"type": "array", "items": {"type": "string"}}, "stimulus": {"type": "string"},
    "observations": {
      "description": "Observable behaviors. Items are either plain strings (v2.0) or structured objects with IDs and verification links (v2.1).",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": ["string", "object"],
        "properties": {
          "id": {"type": "string", "pattern": "^OBS-[0-9]{3,}$", "description": "Stable observation identifier within this BEH contract"},
          "description": {"type": "string", "minLength": 1, "description": "Human-readable description of the observable behavior"},
          "verified_by": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "pattern": "^(EVID|TEST)-[0-9]{4,}$"},
            "description": "Evidence or test IDs that individually exercise this observation"
          },
          "complexity": {
            "enum": ["trivial", "moderate", "complex"],
            "description": "Estimated implementation complexity for depth scoring"
          }
        }
      }
    },
    "evidence": {"type": "array", "items": {"type": "string"}}, "known_gaps": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
