{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/migration-scope.schema.json",
  "title": "Migration source scope and disposition ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "migration_id", "policy", "source_snapshot", "units"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "3.0"},
    "migration_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "required_claim", "allow_approved_removals", "boundary_decisions"],
      "properties": {
        "mode": {"enum": ["whole-source-root", "bounded"]},
        "required_claim": {"enum": ["accounted", "migrated"]},
        "allow_approved_removals": {"type": "boolean"},
        "boundary_decisions": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^DEC-[0-9]{4,}$"}
        }
      }
    },
    "source_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_root", "revision", "captured_at", "digest", "files", "excluded_files"],
      "properties": {
        "source_root": {"$ref": "#/$defs/relativePath"},
        "revision": {"type": ["string", "null"], "minLength": 1},
        "captured_at": {"type": "string", "format": "date-time"},
        "digest": {"$ref": "#/$defs/sha256"},
        "files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {"$ref": "#/$defs/relativePath"},
              "sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        "excluded_files": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "exception"],
            "properties": {
              "path": {"$ref": "#/$defs/relativePath"},
              "sha256": {"$ref": "#/$defs/sha256"},
              "exception": {"type": "string", "pattern": "^EXC-[0-9]{4,}$"}
            }
          }
        }
      }
    },
    "units": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_unit", "disposition", "target_units", "decisions", "exceptions", "rationale"],
        "properties": {
          "source_unit": {"type": "string", "pattern": "^SRC-[0-9]{4,}$"},
          "disposition": {"enum": ["pending", "migrated", "replaced", "removed", "retained"]},
          "target_units": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^TGT-[0-9]{4,}$"}},
          "decisions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^DEC-[0-9]{4,}$"}},
          "exceptions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^EXC-[0-9]{4,}$"}},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "$defs": {
    "relativePath": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
