{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/migration-state.schema.json",
  "title": "Migration execution state",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "migration_id", "revision", "status", "resume_to", "active_slice", "completed_slices", "blocked_by", "last_transition", "history", "validation_status"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "2.0"},
    "migration_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
    "revision": {"type": "integer", "minimum": 0},
    "status": {"enum": ["initialize", "discover", "characterize", "map", "plan", "execute", "verify", "review", "approve", "cut_over", "decommissioned", "blocked", "failed"]},
    "resume_to": {"type": ["string", "null"]},
    "active_slice": {"type": ["string", "null"], "pattern": "^SLICE-[0-9]{4,}$"},
    "completed_slices": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^SLICE-[0-9]{4,}$"}},
    "blocked_by": {"type": "array", "items": {"type": "string"}},
    "last_transition": {"type": "object", "required": ["from", "to", "at", "reason"], "properties": {"from": {"type": ["string", "null"]}, "to": {"type": "string"}, "at": {"type": "string", "format": "date-time"}, "reason": {"type": "string"}}, "additionalProperties": false},
    "history": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["from", "to", "at", "reason"], "properties": {"from": {"type": ["string", "null"]}, "to": {"type": "string"}, "at": {"type": "string", "format": "date-time"}, "reason": {"type": "string"}}, "additionalProperties": false}},
    "validation_status": {"enum": ["unvalidated", "valid", "invalid"]}
  }
}
