{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/profile.schema.json",
  "title": "Composable migration profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_version", "kind", "id", "display_name", "capabilities", "documents", "variables", "provenance"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "2.0"},
    "profile_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "kind": {"enum": ["source", "target", "pair", "output"]},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "display_name": {"type": "string", "minLength": 1},
    "source": {"type": "string"},
    "target": {"type": "string"},
    "capabilities": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}},
    "requires": {
      "type": "object",
      "propertyNames": {"enum": ["source", "target", "pair", "output", "adapter"]},
      "additionalProperties": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^docs/(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.md$"}
    },
    "target_documents": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {"type": "string", "pattern": "^docs/standards/targets/(?!.*(?:^|/)\\.\\.(?:/|$)).+\\.md$"}
      }
    },
    "variables": {
      "type": "object",
      "propertyNames": {"pattern": "^[a-z][a-z0-9_]*$"},
      "additionalProperties": {"type": ["string", "number", "boolean"]}
    },
    "quality_gates": {
      "type": "object",
      "required": ["required", "human_approval", "coverage_policy"],
      "properties": {
        "required": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "human_approval": {"type": "boolean"},
        "coverage_policy": {
          "type": "object",
          "required": ["metric", "project_thresholds_required"],
          "properties": {
            "metric": {"enum": ["behavioral-contract", "changed-code", "public-api", "none"]},
            "project_thresholds_required": {"type": "boolean"}
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "equivalence_policy": {"type": "object", "additionalProperties": {"type": "string"}},
    "provenance": {
      "type": "object",
      "required": ["last_reviewed_version", "evidence"],
      "properties": {
        "last_reviewed_version": {"type": "string"},
        "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {"if": {"properties": {"kind": {"const": "pair"}}}, "then": {"required": ["source", "target", "requires", "equivalence_policy"]}},
    {"if": {"properties": {"kind": {"const": "output"}}}, "then": {"required": ["requires", "quality_gates"]}}
  ]
}
