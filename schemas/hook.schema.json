{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/hook.schema.json",
  "title": "Portable hook definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "trigger", "matcher", "type", "description", "required"],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "trigger": {"enum": ["file-save", "file-create", "file-delete", "pre-tool", "post-tool", "stop", "session-start"]},
    "matcher": {"type": "string", "minLength": 1},
    "type": {"enum": ["command", "agent"]},
    "command": {"type": "string", "minLength": 1},
    "prompt": {"type": "string", "minLength": 1},
    "timeout": {"type": "integer", "minimum": 1, "maximum": 3600},
    "description": {"type": "string", "minLength": 1},
    "required": {"type": "boolean"},
    "enforcement": {"enum": ["deterministic", "judgment"]}
  },
  "allOf": [
    {"if": {"properties": {"type": {"const": "command"}}}, "then": {"required": ["command"]}},
    {"if": {"properties": {"type": {"const": "agent"}}}, "then": {"required": ["prompt"]}}
  ]
}
