{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ai-migration-framework/schemas/plan.schema.json",
  "title": "Dependency-seam migration slice plan",
  "type": "object",
  "required": ["schema_version", "id", "status", "source_units", "behavioral_contracts", "target_units", "dependencies", "release_boundary", "rollback", "verification_gates", "approval_refs"],
  "properties": {
    "$schema": {"type": "string"}, "schema_version": {"const": "2.0"}, "id": {"type": "string", "pattern": "^SLICE-[0-9]{4,}$"}, "status": {"enum": ["planned", "in-progress", "blocked", "failed", "verified", "approved"]}, "source_units": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^SRC-[0-9]{4,}$"}}, "behavioral_contracts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^BEH-[0-9]{4,}$"}}, "target_units": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^TGT-[0-9]{4,}$"}}, "dependencies": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^SLICE-[0-9]{4,}$"}}, "release_boundary": {"type": "string"}, "rollback": {"type": "string"}, "verification_gates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}, "approval_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "additionalProperties": false
}
