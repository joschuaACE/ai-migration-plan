{
  "$schema": "schemas/framework.schema.json",
  "schema_version": "2.0",
  "framework_version": "3.1.0",
  "profile_contract_version": "2.0",
  "name": "ai-migration-framework",
  "default_pair": "cpp-to-java-25",
  "default_output_profile": "service",
  "default_strategy": "incremental",
  "strict_validation": true,
  "merge_precedence": [
    "generic",
    "source",
    "target",
    "pair",
    "output",
    "project"
  ],
  "generic_documents": [
    "docs/standards/generic/architecture-rules.md",
    "docs/standards/generic/incremental-modernization.md",
    "docs/standards/generic/migration-agents.md",
    "docs/standards/generic/migration-completeness.md",
    "docs/standards/generic/migration-philosophy.md",
    "docs/standards/generic/migration-state-files.md",
    "docs/standards/generic/workspace-containment.md"
  ],
  "workflow_documents": [
    "docs/skills/migrate-init.md",
    "docs/skills/migrate-detect.md",
    "docs/skills/migrate-analyze.md",
    "docs/skills/migrate-map.md",
    "docs/skills/migrate-plan.md",
    "docs/skills/migrate-execute.md",
    "docs/skills/migrate-verify.md",
    "docs/skills/migrate-review.md",
    "docs/skills/migrate-audit.md",
    "docs/skills/migrate-cutover.md",
    "docs/skills/migrate-decommission.md",
    "docs/skills/migrate-resume.md",
    "docs/skills/migrate-framework-update.md"
  ],
  "hook_documents": [
    "docs/hooks/migration-quality.md"
  ],
  "provenance_documents": [
    "docs/provenance/rule-metadata.md"
  ],
  "release_documents": [
    "docs/release/checklist.md",
    "docs/release/semantic-versioning.md"
  ],
  "documentation": ["AGENTS.md", "README.md"],
  "required_variables": [
    "source_language",
    "source_language_id",
    "source_extensions",
    "source_extensions_glob",
    "source_test_extensions",
    "source_build_systems",
    "source_package_managers",
    "source_test_frameworks",
    "source_include_directive",
    "source_namespace_concept",
    "target_language",
    "target_language_id",
    "target_build_tool",
    "target_build_file",
    "target_package_concept",
    "target_test_framework",
    "target_source_dir",
    "target_test_dir",
    "compile_command",
    "test_command",
    "test_single_command",
    "architecture_test_command",
    "coverage_command",
    "coverage_report_path",
    "lint_command",
    "pair_id",
    "output_profile",
    "target_framework",
    "architecture_style"
  ],
  "variable_contract": {
    "source_language": {"type": "string", "owner": "source", "description": "Human-readable source language"},
    "source_language_id": {"type": "string", "owner": "source", "description": "Source profile identifier"},
    "source_extensions": {"type": "string", "owner": "source", "description": "Source file extensions"},
    "source_extensions_glob": {"type": "string", "owner": "source", "description": "Portable source search globs"},
    "source_test_extensions": {"type": "string", "owner": "source", "description": "Source test file patterns"},
    "source_build_systems": {"type": "string", "owner": "source", "description": "Recognized source build systems"},
    "source_package_managers": {"type": "string", "owner": "source", "description": "Recognized source package managers"},
    "source_test_frameworks": {"type": "string", "owner": "source", "description": "Recognized source test frameworks"},
    "source_include_directive": {"type": "string", "owner": "source", "description": "Source dependency directive"},
    "source_namespace_concept": {"type": "string", "owner": "source", "description": "Source namespace/module terminology"},
    "target_language": {"type": "string", "owner": "target", "description": "Human-readable target language"},
    "target_language_id": {"type": "string", "owner": "target", "description": "Target profile identifier"},
    "target_build_tool": {"type": "string", "owner": "target", "description": "Target build tool"},
    "target_build_file": {"type": "string", "owner": "target", "description": "Target build definition"},
    "target_package_concept": {"type": "string", "owner": "target", "description": "Target namespace/module terminology"},
    "target_test_framework": {"type": "string", "owner": "target", "description": "Target test stack"},
    "target_source_dir": {"type": "string", "owner": "target", "description": "Target production source directory"},
    "target_test_dir": {"type": "string", "owner": "target", "description": "Target test source directory"},
    "compile_command": {"type": "string", "owner": "target", "description": "Canonical target compilation command"},
    "test_command": {"type": "string", "owner": "target", "description": "Target test command"},
    "test_single_command": {"type": "string", "owner": "target", "description": "Single-test command template"},
    "architecture_test_command": {"type": "string", "owner": "target", "description": "Architecture rule command"},
    "coverage_command": {"type": "string", "owner": "target", "description": "Coverage evidence command"},
    "coverage_report_path": {"type": "string", "owner": "target", "description": "Coverage evidence path"},
    "lint_command": {"type": "string", "owner": "target", "description": "Static-analysis command"},
    "pair_id": {"type": "string", "owner": "pair", "description": "Migration pair identifier"},
    "output_profile": {"type": "string", "owner": "output", "description": "Output profile identifier"},
    "target_framework": {"type": "string", "owner": "output", "description": "Output-specific framework or framework-free declaration"},
    "architecture_style": {"type": "string", "owner": "output", "description": "Output-specific architecture"}
  },
  "schemas": [
    "schemas/framework.schema.json",
    "schemas/profile.schema.json",
    "schemas/adapter-capabilities.schema.json",
    "schemas/hook.schema.json",
    "schemas/bundle-manifest.schema.json",
    "schemas/bundle-manifest-v2.schema.json",
    "schemas/installation-ownership.schema.json",
    "schemas/installation-ownership-v2.schema.json",
    "schemas/migration-config.schema.json",
    "schemas/migration-state.schema.json",
    "schemas/inventory.schema.json",
    "schemas/behavioral-contract.schema.json",
    "schemas/decision.schema.json",
    "schemas/plan.schema.json",
    "schemas/traceability.schema.json",
    "schemas/evidence.schema.json",
    "schemas/evidence-v3.schema.json",
    "schemas/exception.schema.json",
    "schemas/migration-scope.schema.json",
    "schemas/target-inventory.schema.json",
    "schemas/completion-certificate.schema.json",
    "schemas/fixture.schema.json"
  ],
  "state_machine": {
    "initial": "initialize",
    "terminal": ["decommissioned"],
    "states": [
      "initialize",
      "discover",
      "characterize",
      "map",
      "plan",
      "execute",
      "verify",
      "review",
      "approve",
      "cut_over",
      "decommissioned",
      "blocked",
      "failed"
    ],
    "transitions": {
      "initialize": ["discover", "blocked", "failed"],
      "discover": ["characterize", "blocked", "failed"],
      "characterize": ["map", "blocked", "failed"],
      "map": ["plan", "blocked", "failed"],
      "plan": ["execute", "blocked", "failed"],
      "execute": ["verify", "blocked", "failed"],
      "verify": ["review", "execute", "blocked", "failed"],
      "review": ["approve", "execute", "blocked", "failed"],
      "approve": ["plan", "cut_over", "blocked", "failed"],
      "cut_over": ["approve", "decommissioned", "blocked", "failed"],
      "decommissioned": [],
      "blocked": ["initialize", "discover", "characterize", "map", "plan", "execute", "verify", "review", "approve", "cut_over"],
      "failed": ["initialize", "discover", "characterize", "map", "plan", "execute", "verify", "review", "approve", "cut_over"]
    }
  },
  "compatibility": {
    "v1_variables": "docs/templates/variables.json",
    "accepted_pair_aliases": {
      "cpp-java25": "cpp-to-java-25",
      "cpp-to-java25": "cpp-to-java-25"
    },
    "deprecated_variable_aliases": {
      "build_command": "compile_command"
    }
  }
}
