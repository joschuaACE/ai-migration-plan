{
  "$schema": "../../../../schemas/profile.schema.json",
  "schema_version": "2.0",
  "profile_version": "2.0.0",
  "kind": "target",
  "id": "java-25",
  "display_name": "Java 25",
  "capabilities": [
    "compile",
    "test",
    "static-analysis",
    "architecture-validation",
    "coverage",
    "dependency-integrity",
    "module-boundaries"
  ],
  "documents": [
    "docs/standards/targets/java-25/archunit-templates.md",
    "docs/standards/targets/java-25/gradle-version-catalog.md",
    "docs/standards/targets/java-25/runtime-compatibility.md",
    "docs/standards/targets/java-25/target-standards.md"
  ],
  "variables": {
    "target_language": "Java 25",
    "target_language_id": "java-25",
    "target_build_tool": "Gradle",
    "target_build_file": "build.gradle.kts",
    "target_package_concept": "package",
    "target_test_framework": "JUnit 5 and AssertJ",
    "target_source_dir": "src/main/java",
    "target_test_dir": "src/test/java",
    "compile_command": "./gradlew compileJava",
    "test_command": "./gradlew test",
    "test_single_command": "./gradlew test --tests '{class}'",
    "architecture_test_command": "./gradlew test --tests '*ArchitectureTest'",
    "coverage_command": "./gradlew jacocoTestReport jacocoTestCoverageVerification",
    "coverage_report_path": "build/reports/jacoco/test/jacocoTestReport.xml",
    "lint_command": "./gradlew check"
  },
  "provenance": {
    "last_reviewed_version": "2.0.0",
    "evidence": [
      "https://docs.oracle.com/en/java/javase/25/migrate/getting-started.html",
      "https://docs.gradle.org/current/userguide/dependency_verification.html"
    ]
  }
}
