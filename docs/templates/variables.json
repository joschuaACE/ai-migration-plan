{
  "$schema": "Template variable definitions for the migration framework",
  "$version": "1.0",

  "variables": {
    "source_language": {
      "description": "Human-readable source language name",
      "type": "string",
      "example": "C++"
    },
    "source_language_id": {
      "description": "Machine-friendly source language identifier (used in paths, file names)",
      "type": "string",
      "example": "cpp"
    },
    "source_extensions": {
      "description": "Comma-separated list of source file extensions",
      "type": "string",
      "example": ".cpp, .h, .hpp"
    },
    "source_extensions_glob": {
      "description": "Glob pattern for source files (used in grep/find commands)",
      "type": "string",
      "example": "*.cpp *.h *.hpp"
    },
    "source_test_extensions": {
      "description": "Glob pattern for test source files",
      "type": "string",
      "example": "*_test.cpp *_test.h"
    },
    "source_build_systems": {
      "description": "Comma-separated list of common build systems for this language",
      "type": "string",
      "example": "CMake, Make, MSBuild, Meson, Bazel"
    },
    "source_package_managers": {
      "description": "Comma-separated list of package managers",
      "type": "string",
      "example": "Conan, vcpkg"
    },
    "source_test_frameworks": {
      "description": "Comma-separated list of common test frameworks",
      "type": "string",
      "example": "gtest, catch2, doctest, Boost.Test"
    },
    "source_include_directive": {
      "description": "How this language imports/includes other files",
      "type": "string",
      "example": "#include"
    },
    "source_namespace_concept": {
      "description": "What the source language calls its namespace/module system",
      "type": "string",
      "example": "namespace"
    },
    "target_language": {
      "description": "Human-readable target language name",
      "type": "string",
      "example": "Java 25"
    },
    "target_language_id": {
      "description": "Machine-friendly target language identifier",
      "type": "string",
      "example": "java-25"
    },
    "target_framework": {
      "description": "Primary framework for the target (if applicable)",
      "type": "string",
      "example": "Spring Boot 4.x"
    },
    "target_build_tool": {
      "description": "Build tool for target projects",
      "type": "string",
      "example": "Gradle"
    },
    "target_build_file": {
      "description": "Primary build configuration file name",
      "type": "string",
      "example": "build.gradle.kts"
    },
    "target_package_concept": {
      "description": "What the target language calls its namespace/module system",
      "type": "string",
      "example": "package"
    },
    "target_test_framework": {
      "description": "Primary test framework for target",
      "type": "string",
      "example": "JUnit 5 + AssertJ"
    },
    "target_source_dir": {
      "description": "Conventional source directory in target project",
      "type": "string",
      "example": "src/main/java"
    },
    "target_test_dir": {
      "description": "Conventional test directory in target project",
      "type": "string",
      "example": "src/test/java"
    },
    "build_command": {
      "description": "Command to compile the target project",
      "type": "string",
      "example": "./gradlew compileJava"
    },
    "test_command": {
      "description": "Command to run all tests in the target project",
      "type": "string",
      "example": "./gradlew test"
    },
    "test_single_command": {
      "description": "Command template to run a single test class (use {class} placeholder)",
      "type": "string",
      "example": "./gradlew test --tests '{class}'"
    },
    "architecture_test_command": {
      "description": "Command to run architecture validation tests",
      "type": "string",
      "example": "./gradlew test --tests '*HexagonalArchitectureTest'"
    },
    "coverage_command": {
      "description": "Command to generate and verify test coverage",
      "type": "string",
      "example": "./gradlew jacocoTestReport jacocoTestCoverageVerification"
    },
    "pair_id": {
      "description": "Combined source-to-target identifier for pair-specific content",
      "type": "string",
      "example": "cpp-to-java-25"
    }
  },

  "pairs": {
    "cpp-to-java-25": {
      "source_language": "C++",
      "source_language_id": "cpp",
      "source_extensions": ".cpp, .h, .hpp",
      "source_extensions_glob": "*.cpp *.h *.hpp",
      "source_test_extensions": "*_test.cpp *_test.h",
      "source_build_systems": "CMake, Make, MSBuild, Meson, Bazel",
      "source_package_managers": "Conan, vcpkg",
      "source_test_frameworks": "gtest, catch2, doctest, Boost.Test",
      "source_include_directive": "#include",
      "source_namespace_concept": "namespace",
      "target_language": "Java 25",
      "target_language_id": "java-25",
      "target_framework": "Spring Boot 4.x",
      "target_build_tool": "Gradle",
      "target_build_file": "build.gradle.kts",
      "target_package_concept": "package",
      "target_test_framework": "JUnit 5 + AssertJ",
      "target_source_dir": "src/main/java",
      "target_test_dir": "src/test/java",
      "build_command": "./gradlew compileJava",
      "test_command": "./gradlew test",
      "test_single_command": "./gradlew test --tests '{class}'",
      "architecture_test_command": "./gradlew test --tests '*HexagonalArchitectureTest'",
      "coverage_command": "./gradlew jacocoTestReport jacocoTestCoverageVerification",
      "pair_id": "cpp-to-java-25"
    }
  },

  "conditionals": {
    "$note": "Skills can use {{#if source_language_id == 'cpp'}} blocks for source-specific detection procedures that cannot be generalized into a variable.",
    "syntax": {
      "if_block": "{{#if <variable> == '<value>'}} ... {{/if}}",
      "else_block": "{{#else}} ... {{/if}}",
      "include": "{{> path/to/partial.md}}"
    }
  }
}
